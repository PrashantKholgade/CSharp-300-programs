using System;

class Program
{
    static void Main()
    {
        int a = 0, b = 1;

        Console.WriteLine(a);
        Console.WriteLine(b);

        for (int i = 0; i < 8; i++)
        {
            int c = a + b;
            Console.WriteLine(c);
            a = b;
            b = c;
        }
    }
}
