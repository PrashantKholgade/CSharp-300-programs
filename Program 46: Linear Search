using System;

class Program
{
    static void Main()
    {
        int[] arr = { 10, 20, 30, 40, 50 };
        int key = 30;
        bool found = false;

        foreach (int num in arr)
        {
            if (num == key)
            {
                found = true;
                break;
            }
        }

        Console.WriteLine(found ? "Found" : "Not Found");
    }
}
