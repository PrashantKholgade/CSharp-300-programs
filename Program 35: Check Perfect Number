using System;

class Program
{
    static void Main()
    {
        Console.Write("Enter number: ");
        int n = Convert.ToInt32(Console.ReadLine());

        int sum = 0;

        for (int i = 1; i < n; i++)
        {
            if (n % i == 0)
                sum += i;
        }

        if (sum == n)
            Console.WriteLine("Perfect Number");
        else
            Console.WriteLine("Not Perfect Number");
    }
}
